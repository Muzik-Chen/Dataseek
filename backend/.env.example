# ====== 数据库 ======
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chaoshan_platform
DB_POOL_SIZE=10
# DB_ECHO=false                  # 开启后打印 SQL 日志（调试用）

# ====== JWT ======
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-string
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080       # 7 天

# ====== LLM ======
# 可选: zhipu | deepseek
LLM_PROVIDER=zhipu
# -- 智谱 AI (GLM) --
ZHIPU_MODEL=glm-4-flash
ZHIPU_API_KEY=
# -- DeepSeek (备选) --
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=

# ====== 163 SMTP 邮件（注册/找回密码发送验证码）======
# 163邮箱 → 设置 → POP3/SMTP/IMAP → 开启并新增授权密码
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=465
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=

# ====== 天气（和风天气 API）======
# 个人开发者免费 1000次/天，注册地址: https://dev.qweather.com
# WEATHER_API_KEY=

# ====== HuggingFace 镜像（国内加速）======
# 如无法访问 huggingface.co，设置镜像地址:
# HF_ENDPOINT=https://hf-mirror.com

# ====== CORS ======
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ====== 上传 ======
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=5

# ====== Debug ======
DEBUG=true
